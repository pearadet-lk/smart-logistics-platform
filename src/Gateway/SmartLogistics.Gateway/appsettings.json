{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "AllowedHosts": "*",
  "Keycloak": {
    "Authority": "http://localhost:8080/realms/SmartLogistics",
    "Audience": "account"
  },
  "OpenTelemetry": {
    "JaegerEndpoint": "http://localhost:4317"
  },
  "Seq": {
    "ServerUrl": "http://localhost:5341"
  },
  "Elasticsearch": {
    "Url": "http://localhost:9200"
  },
  "FeatureFlags": {
    "NewTariffScreen": true,
    "BillingModule": true,
    "AiAssistant": true,
    "PwaOfflineLookups": true
  },
  "ReverseProxy": {
    "Routes": {
      "shipment-tracking-route": {
        "ClusterId": "tracking-cluster",
        "Order": 1,
        "Match": { "Path": "/api/shipments/{shipmentId}/tracking" },
        "AuthorizationPolicy": "Authenticated",
        "Transforms": [
          { "PathSet": "/api/tracking/shipments/{shipmentId}" }
        ]
      },
      "analytics-route": {
        "ClusterId": "reporting-cluster",
        "Order": 2,
        "Match": { "Path": "/api/analytics/{**catch-all}" },
        "AuthorizationPolicy": "Authenticated"
      },
      "audit-route": {
        "ClusterId": "reporting-cluster",
        "Order": 3,
        "Match": { "Path": "/api/audit/{**catch-all}" },
        "AuthorizationPolicy": "RequireAdmin"
      },
      "shipments-route": {
        "ClusterId": "shipment-cluster",
        "Order": 10,
        "Match": { "Path": "/api/shipments/{**catch-all}" },
        "AuthorizationPolicy": "Authenticated"
      },
      "tariffs-route": {
        "ClusterId": "tariff-cluster",
        "Match": { "Path": "/api/tariffs/{**catch-all}" },
        "AuthorizationPolicy": "Authenticated"
      },
      "invoices-route": {
        "ClusterId": "billing-cluster",
        "Match": { "Path": "/api/invoices/{**catch-all}" },
        "AuthorizationPolicy": "Authenticated"
      },
      "notifications-route": {
        "ClusterId": "notification-cluster",
        "Match": { "Path": "/api/notifications/{**catch-all}" },
        "AuthorizationPolicy": "Authenticated"
      },
      "notifications-hub-route": {
        "ClusterId": "notification-cluster",
        "Match": { "Path": "/hubs/notifications/{**catch-all}" }
      },
      "ai-route": {
        "ClusterId": "ai-cluster",
        "Match": { "Path": "/api/ai/{**catch-all}" },
        "AuthorizationPolicy": "Authenticated"
      }
    },
    "Clusters": {
      "shipment-cluster": {
        "Destinations": {
          "destination1": { "Address": "http://localhost:5101/" }
        }
      },
      "tariff-cluster": {
        "Destinations": {
          "destination1": { "Address": "http://localhost:5102/" }
        }
      },
      "billing-cluster": {
        "Destinations": {
          "destination1": { "Address": "http://localhost:5103/" }
        }
      },
      "notification-cluster": {
        "Destinations": {
          "destination1": { "Address": "http://localhost:5104/" }
        }
      },
      "ai-cluster": {
        "Destinations": {
          "destination1": { "Address": "http://localhost:5105/" }
        }
      },
      "tracking-cluster": {
        "Destinations": {
          "destination1": { "Address": "http://localhost:5106/" }
        }
      },
      "reporting-cluster": {
        "Destinations": {
          "destination1": { "Address": "http://localhost:5107/" }
        }
      }
    }
  }
}
