{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "AllowedHosts": "*",
  "Keycloak": {
    "Authority": "http://localhost:8080/realms/SmartLogistics",
    "Audience": "account"
  },
  "ReverseProxy": {
    "Routes": {
      "shipments-route": {
        "ClusterId": "shipment-cluster",
        "Match": { "Path": "/api/shipments/{**catch-all}" },
        "AuthorizationPolicy": "Authenticated"
      },
      "tariffs-route": {
        "ClusterId": "tariff-cluster",
        "Match": { "Path": "/api/tariffs/{**catch-all}" },
        "AuthorizationPolicy": "Authenticated"
      },
      "invoices-route": {
        "ClusterId": "billing-cluster",
        "Match": { "Path": "/api/invoices/{**catch-all}" },
        "AuthorizationPolicy": "Authenticated"
      },
      "notifications-route": {
        "ClusterId": "notification-cluster",
        "Match": { "Path": "/api/notifications/{**catch-all}" },
        "AuthorizationPolicy": "Authenticated"
      }
    },
    "Clusters": {
      "shipment-cluster": {
        "Destinations": {
          "destination1": { "Address": "http://localhost:5101/" }
        }
      },
      "tariff-cluster": {
        "Destinations": {
          "destination1": { "Address": "http://localhost:5102/" }
        }
      },
      "billing-cluster": {
        "Destinations": {
          "destination1": { "Address": "http://localhost:5103/" }
        }
      },
      "notification-cluster": {
        "Destinations": {
          "destination1": { "Address": "http://localhost:5104/" }
        }
      }
    }
  }
}
