FROM mcr.microsoft.com/dotnet/sdk:10.0 AS build
WORKDIR /src
COPY ["src/Shared/SmartLogistics.Shared/SmartLogistics.Shared.csproj", "Shared/SmartLogistics.Shared/"]
COPY ["src/Services/Tracking/SmartLogistics.Tracking.Api/SmartLogistics.Tracking.Api.csproj", "Services/Tracking/SmartLogistics.Tracking.Api/"]
RUN dotnet restore "Services/Tracking/SmartLogistics.Tracking.Api/SmartLogistics.Tracking.Api.csproj"
COPY src/Shared/SmartLogistics.Shared/ Shared/SmartLogistics.Shared/
COPY src/Services/Tracking/SmartLogistics.Tracking.Api/ Services/Tracking/SmartLogistics.Tracking.Api/
WORKDIR /src/Services/Tracking/SmartLogistics.Tracking.Api
RUN dotnet publish -c Release -o /app/publish --no-restore

FROM mcr.microsoft.com/dotnet/aspnet:10.0 AS final
WORKDIR /app
EXPOSE 8080
ENV ASPNETCORE_URLS=http://+:8080
COPY --from=build /app/publish .
ENTRYPOINT ["dotnet", "SmartLogistics.Tracking.Api.dll"]
