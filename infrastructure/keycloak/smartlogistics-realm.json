{
  "realm": "SmartLogistics",
  "enabled": true,
  "displayName": "Smart Logistics Platform",
  "sslRequired": "external",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "resetPasswordAllowed": true,
  "bruteForceProtected": true,
  "browserFlow": "SmartLogistics Browser MFA",
  "otpPolicyType": "totp",
  "otpPolicyAlgorithm": "HmacSHA1",
  "otpPolicyDigits": 6,
  "otpPolicyPeriod": 30,
  "roles": {
    "realm": [
      { "name": "Admin", "description": "Internal staff — full platform access" },
      { "name": "Operations", "description": "Internal staff — shipment operations" },
      { "name": "Finance", "description": "Internal staff — billing and invoices" },
      { "name": "Sales", "description": "Internal staff — sales and tariffs" },
      { "name": "Partner", "description": "External partner access" },
      { "name": "Customer", "description": "External customer" },
      { "name": "Carrier", "description": "External carrier" }
    ],
    "client": {
      "shipment-api": [
        { "name": "Shipment.Read" },
        { "name": "Shipment.Create" },
        { "name": "Shipment.Update" },
        { "name": "Shipment.Delete" }
      ],
      "tariff-api": [
        { "name": "Tariff.Read" },
        { "name": "Tariff.Update" },
        { "name": "Tariff.Approve" }
      ],
      "billing-api": [
        { "name": "Invoice.Read" },
        { "name": "Invoice.Write" }
      ]
    }
  },
  "groups": [
    {
      "name": "Customers",
      "subGroups": [
        { "name": "DHL", "attributes": { "partnerId": ["1001"], "company": ["DHL"], "tenant": ["DHL"] } },
        { "name": "FedEx", "attributes": { "partnerId": ["1002"], "company": ["FedEx"], "tenant": ["FedEx"] } }
      ]
    },
    {
      "name": "Carriers",
      "subGroups": [
        { "name": "Maersk", "attributes": { "partnerId": ["2001"], "company": ["Maersk"], "tenant": ["Maersk"] } }
      ]
    }
  ],
  "users": [
    {
      "username": "admin",
      "email": "admin@smartlogistics.local",
      "firstName": "Platform",
      "lastName": "Admin",
      "enabled": true,
      "emailVerified": true,
      "requiredActions": ["CONFIGURE_TOTP"],
      "realmRoles": ["Admin"],
      "credentials": [{ "type": "password", "value": "admin", "temporary": false }]
    },
    {
      "username": "finance",
      "email": "finance@smartlogistics.local",
      "firstName": "Finance",
      "lastName": "User",
      "enabled": true,
      "emailVerified": true,
      "requiredActions": ["CONFIGURE_TOTP"],
      "realmRoles": ["Finance"],
      "credentials": [{ "type": "password", "value": "finance", "temporary": false }]
    },
    {
      "username": "ops",
      "email": "ops@smartlogistics.local",
      "firstName": "Operations",
      "lastName": "User",
      "enabled": true,
      "emailVerified": true,
      "realmRoles": ["Operations"],
      "credentials": [{ "type": "password", "value": "ops", "temporary": false }]
    }
  ],
  "clients": [
    {
      "clientId": "smartlogistics-web",
      "name": "Customer Portal (Angular)",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "protocol": "openid-connect",
      "redirectUris": ["http://localhost:4200/*"],
      "webOrigins": ["http://localhost:4200"],
      "attributes": { "pkce.code.challenge.method": "S256" }
    },
    {
      "clientId": "admin-web",
      "name": "Admin Portal (Angular SSO)",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "protocol": "openid-connect",
      "redirectUris": ["http://localhost:4200/*"],
      "webOrigins": ["http://localhost:4200"],
      "attributes": { "pkce.code.challenge.method": "S256" }
    },
    {
      "clientId": "partner-web",
      "name": "Partner Portal (Angular SSO)",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "protocol": "openid-connect",
      "redirectUris": ["http://localhost:4200/*"],
      "webOrigins": ["http://localhost:4200"],
      "attributes": { "pkce.code.challenge.method": "S256" }
    },
    {
      "clientId": "shipment-api",
      "enabled": true,
      "bearerOnly": true,
      "protocol": "openid-connect"
    },
    {
      "clientId": "tariff-api",
      "enabled": true,
      "bearerOnly": true,
      "protocol": "openid-connect"
    },
    {
      "clientId": "billing-api",
      "enabled": true,
      "bearerOnly": true,
      "protocol": "openid-connect"
    },
    {
      "clientId": "notification-api",
      "enabled": true,
      "bearerOnly": true,
      "protocol": "openid-connect"
    },
    {
      "clientId": "integration-client",
      "enabled": true,
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": false,
      "protocol": "openid-connect"
    }
  ],
  "identityProviders": [
    {
      "alias": "google",
      "displayName": "Google",
      "providerId": "google",
      "enabled": false,
      "config": { "clientId": "PLACEHOLDER", "clientSecret": "PLACEHOLDER" }
    },
    {
      "alias": "github",
      "displayName": "GitHub",
      "providerId": "github",
      "enabled": true,
      "trustEmail": true,
      "storeToken": false,
      "linkOnly": false,
      "config": {
        "clientId": "PLACEHOLDER_GITHUB_CLIENT_ID",
        "clientSecret": "PLACEHOLDER_GITHUB_CLIENT_SECRET",
        "defaultScope": "read:user user:email"
      }
    },
    {
      "alias": "microsoft",
      "displayName": "Microsoft",
      "providerId": "microsoft",
      "enabled": false,
      "config": { "clientId": "PLACEHOLDER", "clientSecret": "PLACEHOLDER" }
    }
  ],
  "authenticationFlows": [
    {
      "alias": "SmartLogistics Browser MFA",
      "description": "Username/password + TOTP (Google/Microsoft Authenticator)",
      "providerId": "basic-flow",
      "topLevel": true,
      "builtIn": false,
      "authenticationExecutions": [
        {
          "authenticator": "auth-cookie",
          "authenticatorFlow": false,
          "requirement": "ALTERNATIVE",
          "priority": 10,
          "userSetupAllowed": false
        },
        {
          "authenticator": "auth-spnego",
          "authenticatorFlow": false,
          "requirement": "DISABLED",
          "priority": 20,
          "userSetupAllowed": false
        },
        {
          "authenticator": "identity-provider-redirector",
          "authenticatorFlow": false,
          "requirement": "ALTERNATIVE",
          "priority": 25,
          "userSetupAllowed": false
        },
        {
          "authenticator": "auth-username-password-form",
          "authenticatorFlow": false,
          "requirement": "REQUIRED",
          "priority": 30,
          "userSetupAllowed": false
        },
        {
          "authenticator": "auth-otp-form",
          "authenticatorFlow": false,
          "requirement": "REQUIRED",
          "priority": 40,
          "userSetupAllowed": false
        }
      ]
    }
  ],
  "requiredActions": [
    { "alias": "CONFIGURE_TOTP", "name": "Configure OTP", "enabled": true, "defaultAction": false, "priority": 10 }
  ],
  "clientScopes": [
    {
      "name": "permissions",
      "protocol": "openid-connect",
      "attributes": { "include.in.token.scope": "true" },
      "protocolMappers": [
        {
          "name": "client-roles-permission",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-client-role-mapper",
          "config": {
            "multivalued": "true",
            "userinfo.token.claim": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "permission",
            "jsonType.label": "String"
          }
        },
        {
          "name": "company-claim",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "config": {
            "user.attribute": "company",
            "claim.name": "company",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "tenant-claim",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "config": {
            "user.attribute": "tenant",
            "claim.name": "tenant",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    }
  ]
}
